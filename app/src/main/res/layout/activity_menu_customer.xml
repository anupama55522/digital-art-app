<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MenuCustomer">

    <ImageView
        android:id="@+id/profileIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/user"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="76dp"/>

    <Button
        android:id="@+id/profileCustomer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:textSize="18sp"
        android:backgroundTint="@color/black"
        android:textColor="@color/white"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/profileIcon"
        app:layout_constraintStart_toStartOf="@id/profileIcon"
        app:layout_constraintEnd_toEndOf="@id/profileIcon"
        android:layout_marginTop="106dp"
        android:layout_marginStart="-40dp"
        android:layout_marginEnd="-50dp"
        />
    <Button
        android:id="@+id/HistoryButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="History"
        android:textSize="18sp"
        android:backgroundTint="@color/black"
        android:textColor="@color/white"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/profileCustomer"
        app:layout_constraintStart_toStartOf="@id/profileCustomer"
        app:layout_constraintEnd_toEndOf="@id/profileCustomer"
        android:layout_marginTop="25dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        />
    <Button
        android:id="@+id/logoutCustomer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textSize="18sp"
        android:backgroundTint="@color/black"
        android:textColor="@color/white"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/HistoryButton"
        app:layout_constraintStart_toStartOf="@id/HistoryButton"
        app:layout_constraintEnd_toEndOf="@id/HistoryButton"
        android:layout_marginTop="25dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        />

</androidx.constraintlayout.widget.ConstraintLayout>
